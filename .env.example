# Telegram bot token from BotFather.
# You can also use TGTOKEN instead of TELEGRAM_BOT_TOKEN.
TELEGRAM_BOT_TOKEN=123456:replace_me

# Optional: comma-separated Telegram user IDs allowed to use bot commands.
# Leave empty to allow anyone who knows the bot.
ADMIN_IDS=

# Rapira public rates endpoint and field for USDT/RUB.
RAPIRA_RATES_URL=https://api.rapira.net/open/market/rates
RAPIRA_SYMBOL=USDT/RUB
RAPIRA_PRICE_FIELD=close

# Coinbase public exchange-rates endpoint.
COINBASE_RATES_URL=https://api.coinbase.com/v2/exchange-rates
COINBASE_BASE_CURRENCY=USDT
COINBASE_QUOTE_CURRENCY=CNY

# Your correction from Rapira market rate to the rate you stand at.
# Example: 74.83 -> 77.00 equals +2.9%.
RAPIRA_MARKUP_PERCENT=2.9

# Extra markup over calculated CNY cost, in RUB per 1 CNY.
# Typical margin: 0.15-0.20.
PUBLIC_MARKUP_RUB=0.20

# Rounding for the final displayed public rate.
ROUND_TO=0.05
ROUND_UP=true

REQUEST_TIMEOUT_SECONDS=10

# Tier output settings.
# POST_TIERS format: min_cny:extra_markup_over_base_rate.
POST_TIERS=1000:0.15;3000:0.10;10000:0.05;30000:0.00
CHECK_RATE_RUB=12.00
MIN_EXCHANGE_CNY=500
TRIAL_EXCHANGE_CNY=100

# Leave empty to calculate from API, or set manually for the post block.
USDT_BUY_RATE_RUB=
USDT_SELL_RATE_RUB=
USDT_BUY_OFFSET_RUB=4
USDT_SELL_OFFSET_RUB=-3
USDT_CNY_REGULAR=6.61
USDT_CNY_BIG=6.68
USDT_CNY_BIG_FROM=10000

CONTACT_USERNAME=@exchange_kir
REVIEWS_USERNAME=@otzivi_17teen
CHAT_USERNAME=@chat_17teen
MAX_URL=https://max.ru/u/f9LHodD0cOIlGK214Iw7B-Xt7rBa_q85OmfEK61yQXs8e0apAqgArel29NI

# On the web server this file is read by the static site.
SITE_RATES_PATH=/var/www/17exchange/rates.json
